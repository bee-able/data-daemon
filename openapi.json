                        "name",
                        "schemaVersion",
                        "metadata",
                        "createdAt",
                        "updatedAt"
                      ],
                      "properties": {
                        "id": {
                          "type": "string",
                          "format": "uuid"
                        },
                        "namespaceId": {
                          "type": "string",
                          "format": "uuid"
                        },
                        "name": {
