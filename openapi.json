            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "where",
            "required": false,
            "in": "query",
            "description": "JSON-encoded equality predicate object",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "schema": {
              "type": "integer"
