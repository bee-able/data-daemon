# Create the real secret on the cluster with:
#   kubectl create secret generic data-daemon-secrets -n beeable \
#     --from-literal=DATABASE_URL='<copy from knowledge-daemon-secrets>'
#
# EXECUTION_TOKEN_SIGNING_KEY is sourced from beeable-api-secrets at the
# deployment level (see k8s/deployment.yaml), not here — same pattern as
# crawler-daemon. This file is a reference only — do not check in real secrets.
apiVersion: v1
kind: Secret
metadata:
  name: data-daemon-secrets
  namespace: beeable
type: Opaque
stringData:
  DATABASE_URL: "postgresql://platform:REPLACE_ME@platform-pg-rw.platform.svc:5432/platform?sslmode=no-verify"
